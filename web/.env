# ==============================================================================
# Polymarket Hunter - Root Environment Configuration (Fallback)
# ==============================================================================
# 提示: 如果没有对应的 .env.local.* 文件，会作为基础回退(Fallback)加载。
# 注意: 这里定义的环境变量 Prisma 无法直接加载！
# 请在 `prisma.config.ts` 里 import "dotenv/config";
# ------------------------------------------------------------------------------

# ==========================================
# 1. 基础网络与节点配置 (Network & RPC)
# ==========================================
# 【必填 (Required)】当前运行的网络环境标识 (比如 localhost / amoy / polygon)
NEXT_PUBLIC_NETWORK=polygon

# 【必填 (Required)】当前网络的 Chain ID (Polygon主网=137, Hardhat跑本地=1337/31337)
NEXT_PUBLIC_CHAIN_ID=137

# 【必填 (Required)】供前端与客户端使用的基础 RPC 访问节点地址，主网上建议替换为自己申请的独享节点以提速
NEXT_PUBLIC_RPC_URL=https://polygon-rpc.com

# 【可选 (Optional)】Polygon 网络专用的 Websocket RPC 节点链接
POLYGON_WS=wss://polygon-bor-rpc.publicnode.com

# 【可选 (Optional)】在本地或测试环境下复刻主网状态时使用的 RPC 地址 (Hardhat Fork)
MAINNET_FORK_RPC_URL=

# ==========================================
# 2. Polymarket 智能合约地址 (Smart Contracts)
# ==========================================
# 【必填 (Required)】代理钱包工厂 (Proxy Factory) 智能合约地址，用于为新用户创建独立的代理钱包
NEXT_PUBLIC_PROXY_FACTORY_ADDRESS="0xDeF8a62f50BA3B9f319B473c48928595A333acba"

# 【必填 (Required)】国库/资金池 (Treasury) 智能合约地址，用于接受手续费或者统一的全局资产沉淀
NEXT_PUBLIC_TREASURY_ADDRESS="0xF1a7a5060f22edA40b1A94a858995fa2bcf5E75A"

# 【必填 (Required)】订单执行器 (Executor) 智能合约地址，专门负责将代打的交易动作在链上落地
NEXT_PUBLIC_EXECUTOR_ADDRESS="0x7EC2de2B81fDCe52E4B44cE641D535E1e0e3982B"

# 【必填 (Required)】USDC 稳定币的合约地址
NEXT_PUBLIC_USDC_ADDRESS=

# 【必填 (Required)】Polymarket 本身的条件代币框架 (CTF) 合约地址
NEXT_PUBLIC_CTF_ADDRESS=

# 【可选 (Optional)】自主跟单机器人 (Bot) 的核心管理合约地址
NEXT_PUBLIC_BOT_ADDRESS=

# 提示: 主网后台读库用的国库地址
TREASURY_ADDRESS=

# ==========================================
# 3. 核心密钥与鉴权 (Secrets & Auth)
# ==========================================
# 【必填 (Required)】核心业务数据库 Prisma 连接字符串 (例如 PostgreSQL 或 SQLite)
DATABASE_URL="postgresql://baronchan@localhost:5432/poly_hunter_dev?schema=public"

# 【可选 (Optional)】系统的真实交易发起钱包 (EOA) 私钥 (严禁提交代码库，填入 .env.local 即生效)
TRADING_PRIVATE_KEY=

# 【可选 (Optional)】系统的真实交易发起钱包助记词 (可与上述私钥二选一)
TRADING_MNEMONIC=

# 【可选 (Optional)】Polymarket 官方 CLOB 订单簿 API，用于现货鉴权 (必须与系统交易钱包一致)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ==========================================
# 4. 跟单交易引擎核心参数 (Copy Trading Execution)
# ==========================================
# 【必填 (Required)】是否开启真实跟单？=false时只会打印执行日志或发送模拟订单
ENABLE_REAL_TRADING=

# 【可选 (Optional)】专门留给高频发信后台的独立 RPC 节点（独立配置防止和前端抢夺请求额度被限流）
COPY_TRADING_RPC_URL=

# 【可选 (Optional)】Websocket 协议下是否强制向官方服务器发送地址过滤条件来极大减少无关消息造成的解码压力
COPY_TRADING_WS_FILTER_BY_ADDRESS=true

# 【可选 (Optional)】执行者上岗白名单 - 如果设置了只有这个表里的跟单终端才会收到执行分派 (做灰度测试)
COPY_TRADING_EXECUTION_ALLOWLIST=

# ==========================================
# 5. 风控与安全限制 (Risk Management & Guardrails)
# ==========================================
# 【可选 (Optional)】整个系统单日总计允许的最大跟单支出限额 (USD)
COPY_TRADING_DAILY_CAP_USD=

# 【可选 (Optional)】针对每一个独立代理钱包的单日最高支出限额 (USD)
COPY_TRADING_WALLET_DAILY_CAP_USD=

# ==========================================
# 6. 后台监控与架构调优 (Supervisor & Architecture)
# ==========================================
# 【可选 (Optional)】查询盘口价格的缓存生存期 (降低限流概率) (毫秒)
COPY_TRADING_PRICE_TTL_MS=

# ==========================================
# 8. 极速发单防夹模式 (Speed Mode & Mempool)
# ==========================================
# 【可选 (Optional)】内存池发单隐蔽通道提供商 (STANDARD=标准公开链内存池, ALCHEMY=使用加密防夹交易池)
#MEMPOOL_PROVIDER=Alchemy

# 【可选 (Optional)】若设置了 ALCHEMY 的提供商配置项，则必须填写该防夹池对外的开发者 API Key
#NEXT_PUBLIC_ALCHEMY_API_KEY=


# ==========================================
# 9. 托管理财 Worker 配置 (Managed Wealth Worker)
# ==========================================
# 【可选】Worker 循环间隔（毫秒，最低 10000）
MANAGED_WEALTH_LOOP_INTERVAL_MS=60000

# 【可选】每轮最多处理的 Execution Mapping 数量
MANAGED_WEALTH_MAP_BATCH_SIZE=100

# 【可选】每轮最多刷新的 NAV 数量
MANAGED_WEALTH_NAV_BATCH_SIZE=500

# 【可选】每轮最多结算的认购数量
MANAGED_WEALTH_SETTLEMENT_BATCH_SIZE=300

# 【可选】每 N cycle 做一次全量 mapping 扫描（对齐 Agent 配置变更，默认每 20 轮 ≈ 20 分钟）
MANAGED_WEALTH_FULL_REFRESH_INTERVAL=20

# 【可选】NAV 回撤超过此比例时写入 DRAWDOWN_ALERT 风险事件（0.25 = 25%）
MANAGED_NAV_DRAWDOWN_ALERT_THRESHOLD=0.25

# 【可选】清仓 Worker 重试的基准退避间隔（ms）
MANAGED_LIQUIDATION_RETRY_BASE_MS=120000

# 【可选】清仓任务最大重试次数（超过后标记 FAILED）
MANAGED_LIQUIDATION_MAX_ATTEMPTS=50

# ==========================================
# 10. 托管理财 API 配置 (Managed Wealth API)
# ==========================================
# 【可选】最低认购本金（USD）
PARTICIPATION_MANAGED_MIN_PRINCIPAL_USD=500

# 【可选】提前赎回冷静期（小时）
MANAGED_WITHDRAW_COOLDOWN_HOURS=6

# 【可选】提前赎回费率（0.01 = 1%）
MANAGED_EARLY_WITHDRAW_FEE_RATE=0.01

# 【可选】提前赎回回撤预警阈值（0.35 = 35%）
MANAGED_WITHDRAW_DRAWDOWN_ALERT_THRESHOLD=0.35

# 【可选】认购频率限制窗口（ms，默认 5 分钟）
MANAGED_RATE_LIMIT_WINDOW_MS=300000

# 【可选】频率限制窗口内最多创建认购数
MANAGED_RATE_LIMIT_MAX_PER_WINDOW=3

# 【可选】账户最低年龄（天），小于此值不可获得 1 天试用
MANAGED_TRIAL_MIN_ACCOUNT_AGE_DAYS=1

# 【策略门控】是否要求激活注册才能认购（true/false）
PARTICIPATION_REQUIRE_MANAGED_ACTIVATION=false

# 【策略门控】是否要求托管授权（CustodyAuth）才能认购（true/false）
PARTICIPATION_REQUIRE_CUSTODY_AUTH=false
