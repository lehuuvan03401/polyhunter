# ------------------------------------------------------------------------------
# Polymarket Hunter - Production Environment Template (Fail-Close Defaults)
# Keys only + safe defaults. Do not put real secrets into this file.
# ------------------------------------------------------------------------------

# Runtime
NODE_ENV=production

# Network / Chain
NEXT_PUBLIC_NETWORK=polygon
CHAIN_ID=137
NEXT_PUBLIC_CHAIN_ID=137
NEXT_PUBLIC_RPC_URL=https://polygon-rpc.com
COPY_TRADING_RPC_URL=
POLYGON_WS=

# Contracts (set by deployment)
NEXT_PUBLIC_PROXY_FACTORY_ADDRESS=
NEXT_PUBLIC_TREASURY_ADDRESS=
NEXT_PUBLIC_EXECUTOR_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_CTF_ADDRESS=
NEXT_PUBLIC_BOT_ADDRESS=
TREASURY_ADDRESS=

# Database / Infra
DATABASE_URL=
POSTGRES_PRISMA_URL=
SUPERVISOR_REDIS_URL=
REDIS_URL=
ADMIN_WALLETS=

# Secrets / Auth (required in production runtime)
TRADING_PRIVATE_KEY=
TRADING_MNEMONIC=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
CRON_SECRET=
ENCRYPTION_KEY=

# Copy-trading safety gates (fail-close defaults)
ENABLE_REAL_TRADING=false
COPY_TRADING_DRY_RUN=true
COPY_TRADING_EMERGENCY_PAUSE=true
COPY_TRADING_REQUIRE_SIGNATURE=true
COPY_TRADING_SIMULATION_ENABLED=false
NEXT_PUBLIC_E2E_MOCK_AUTH=false

# Copy-trading risk controls (set intentionally before go-live)
COPY_TRADING_DAILY_CAP_USD=
COPY_TRADING_WALLET_DAILY_CAP_USD=
COPY_TRADING_MARKET_DAILY_CAP_USD=
COPY_TRADING_MAX_TRADE_USD=
COPY_TRADING_MAX_TRADES_PER_WINDOW=
COPY_TRADING_TRADE_WINDOW_MS=600000
COPY_TRADING_EXECUTION_ALLOWLIST=
COPY_TRADING_WORKER_ALLOWLIST=
COPY_TRADING_WS_FILTER_BY_ADDRESS=true
COPY_TRADING_PRICE_TTL_MS=5000
COPY_TRADING_IDEMPOTENCY_BUCKET_MS=5000
COPY_TRADING_MIN_WALLET_MATIC=0.1
COPY_TRADING_MIN_PROXY_USDC=1

# Copy-trading reliability / retry
COPY_TRADING_MAX_RETRY_ATTEMPTS=2
COPY_TRADING_RETRY_BACKOFF_MS=60000
COPY_TRADING_RETRY_INTERVAL_MS=60000

# Async settlement / ledger (explicit off by default)
COPY_TRADING_ASYNC_SETTLEMENT=false
COPY_TRADING_SETTLEMENT_MAX_RETRY_ATTEMPTS=5
COPY_TRADING_SETTLEMENT_RETRY_BACKOFF_MS=60000
COPY_TRADING_LEDGER_ENABLED=false
COPY_TRADING_LEDGER_FLUSH_AMOUNT=100
COPY_TRADING_LEDGER_MAX_AGE_MS=300000
COPY_TRADING_LEDGER_OUTSTANDING_CAP=0
COPY_TRADING_LEDGER_FLUSH_INTERVAL_MS=60000
COPY_TRADING_LEDGER_MAX_RETRY_ATTEMPTS=5
COPY_TRADING_LEDGER_RETRY_BACKOFF_MS=60000
COPY_TRADING_LEDGER_CLAIM_BATCH=50

# Supervisor / signal mode
COPY_TRADING_SIGNAL_MODE=HYBRID
SUPERVISOR_POLLING_BASE_INTERVAL_MS=5000
SUPERVISOR_POLLING_MAX_INTERVAL_MS=10000
SUPERVISOR_POLLING_LIMIT=200
SUPERVISOR_POLLING_LOOKBACK_SECONDS=90
SUPERVISOR_WS_UNHEALTHY_THRESHOLD_MS=30000
SUPERVISOR_SIGNAL_SOURCE_WINDOW_MS=120000
SUPERVISOR_WORKER_POOL_SIZE=10
SUPERVISOR_FANOUT_CONCURRENCY=50
SUPERVISOR_CONFIG_FULL_REFRESH_MS=3600000
SUPERVISOR_CONFIG_REFRESH_MS=300000
SUPERVISOR_QUEUE_MAX_SIZE=10000
SUPERVISOR_SHARD_COUNT=1
SUPERVISOR_SHARD_INDEX=0

# Metrics / monitoring
COPY_TRADING_METRICS_INTERVAL_MS=300000
COPY_TRADING_GUARDRAIL_LOG_INTERVAL_MS=60000
COPY_TRADING_GUARDRAIL_ALERT_THRESHOLD=20
COPY_TRADING_PROXY_CHECK_LIMIT=5
ORDERS_LOG_PATH=./logs/orders.log

# Performance / optional speed mode
MEMPOOL_PROVIDER=STANDARD
COPY_TRADING_SPEED_MODE=false
COPY_TRADING_SPEED_PROFILE=standard
COPY_TRADING_MAX_SPREAD_BPS=80
COPY_TRADING_MIN_DEPTH_USD=10
COPY_TRADING_MIN_DEPTH_RATIO=1.2
COPY_TRADING_DEPTH_LEVELS=5

# Managed wealth worker
MANAGED_WEALTH_LOOP_INTERVAL_MS=60000
MANAGED_WEALTH_MAP_BATCH_SIZE=100
MANAGED_WEALTH_NAV_BATCH_SIZE=500
MANAGED_WEALTH_SETTLEMENT_BATCH_SIZE=300
MANAGED_WEALTH_FULL_REFRESH_INTERVAL=20
MANAGED_WEALTH_REQUIRE_SIGNATURE=true
MANAGED_WEALTH_RUN_ONCE=false
MANAGED_NAV_DRAWDOWN_ALERT_THRESHOLD=0.25
MANAGED_LIQUIDATION_RETRY_BASE_MS=120000
MANAGED_LIQUIDATION_MAX_ATTEMPTS=50

# Managed wealth API
PARTICIPATION_MANAGED_MIN_PRINCIPAL_USD=500
MANAGED_WITHDRAW_COOLDOWN_HOURS=6
MANAGED_EARLY_WITHDRAW_FEE_RATE=0.01
MANAGED_WITHDRAW_DRAWDOWN_ALERT_THRESHOLD=0.35
MANAGED_RATE_LIMIT_WINDOW_MS=300000
MANAGED_RATE_LIMIT_MAX_PER_WINDOW=3
MANAGED_TRIAL_MIN_ACCOUNT_AGE_DAYS=1

# Participation policy gates (explicit true for production intent)
PARTICIPATION_REQUIRE_MANAGED_ACTIVATION=true
PARTICIPATION_REQUIRE_CUSTODY_AUTH=true

# Public app switches
NEXT_PUBLIC_MANAGED_WEALTH_SIGN_REQUESTS=true

# Keep simulation/debug vars empty in production
FOLLOWER_WALLET=
TARGET_TRADER=
TARGET_FUND_ADDRESS=
FIXED_COPY_AMOUNT=10
SIM_COPY_MODE=
SIM_ACTIVITY_FILTER=
SIM_WS_SERVER_FILTER=false
COPY_MODE=
MAX_BUDGET=
MAX_TRADE_SIZE=
EST_LEADER_VOLUME=
SCALE_FACTOR=
